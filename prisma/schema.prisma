// Ordinat Dashboard — data schema.
// Schema changes: `npx prisma migrate dev --name <description>` then `npx prisma generate`.
//
// NOTE: identity/auth lives entirely in Supabase's own `auth` schema
// (auth.users), managed by Supabase Auth — not modeled here. There is no
// local User/Role table: any user that can sign in to this Supabase project
// IS an admin (no public signup, no roles). See CLAUDE.md > Auth model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled (pgbouncer) connection — used at runtime by the app.
  url       = env("DATABASE_URL")
  // Direct connection — required by Prisma Migrate, bypasses the pooler.
  directUrl = env("DIRECT_URL")
}

enum EventStatus {
  SCHEDULED // Terjadwal
  ONGOING // Sedang Psikotes
  REKAP // Tahap Rekap
  DONE // Tahap Resume
}

model School {
  id              String          @id @default(cuid())
  name            String // "SMAN 1 CIWARINGIN"
  slug            String          @unique // "CIWARINGIN26" — used in the tiny.cc URL pattern
  // One Google Sheets spreadsheet ID, 12 internal tabs (one per subtest,
  // mirrors Flask's RAW workbook shape) — read-only, used by Monitoring
  // (FR-11/FR-15). NOT a folder — there is no per-school Drive folder;
  // recap results all go to one shared folder (GOOGLE_DRIVE_RESULTS_FOLDER_ID
  // env var), distinguished by filename instead. See CLAUDE.md > Domain.
  driveRawSheetId String?
  events          PsikotesEvent[]
  kelas           Kelas[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([name])
}

// Persists across test events/years, same as School itself — not tied to a
// specific PsikotesEvent. `tester` is a free-text PIC name, unrelated to the
// TESTER account role (naming collision, same word different concept — see
// CLAUDE.md > Domain > Kelas & tester).
model Kelas {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String // free text, e.g. "X-1" — not an enum, schools name kelas differently
  tester    String? // PIC name; null = not assigned yet
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// Fixed lookup; seeded once from SUBTEST_TYPES (src/lib/constants.ts).
// `code` must match the RAW sheet name used by the Automated Recap tool.
model SubtestType {
  id    String        @id @default(cuid())
  code  String        @unique // EPPS, SE, WA, AN, GE, RA, ZR, FA, WU, ME, RIASEC, GB
  label String
  order Int           @default(0)
  links SubtestLink[]
}

model PsikotesEvent {
  id                String        @id @default(cuid())
  schoolId          String
  school            School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  scheduledDate     DateTime
  status            EventStatus   @default(SCHEDULED)
  links             SubtestLink[]
  recapJobs         RecapJob[]
  createdById       String? // auth.users.id (Supabase) of the admin who created this event — no FK, cross-schema
  // Subtest codes this event actually runs (defaults to all 12, EPPS→GB).
  // CONVENTION: an empty array means "all 12" (unconfigured) — so existing
  // rows need no backfill and resolveActiveSubtests() maps [] → the full set.
  // Drives which subtest link slots show in Manajemen Link + the Link Subtes
  // views; Monitoring's submission summary is unaffected (it reads the raw
  // sheet's physical tabs, a different axis). See src/lib/constants.ts.
  activeSubtests    String[]      @default([])
  // Drive file ID of the uploaded recap result (FR-16). Presence means
  // "we've uploaded before" — the next upload updates this file in place
  // (same ID, new content) instead of creating a duplicate. Nullable;
  // absence just means no result uploaded yet, not an error state.
  driveResultFileId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([scheduledDate])
}

model SubtestLink {
  id            String        @id @default(cuid())
  eventId       String
  event         PsikotesEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subtestTypeId String
  subtestType   SubtestType   @relation(fields: [subtestTypeId], references: [id], onDelete: Cascade)
  url           String
  updatedAt     DateTime      @updatedAt

  @@unique([eventId, subtestTypeId]) // one URL per subtest per event
}

// Audit trail for every time the "Mulai Rekap" flag is pressed in the tool (via internal webhook).
// Does not store the recap file — it's generated & downloaded directly from the Flask tool.
model RecapJob {
  id          String        @id @default(cuid())
  eventId     String
  event       PsikotesEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  triggeredBy String // admin email who pressed the flag in the tool
  startedAt   DateTime      @default(now())
  finishedAt  DateTime? // set when the admin presses "Tandai Selesai" in the Rekap Menu

  @@index([eventId])
}
