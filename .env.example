# ── Supabase ──
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ganti-dengan-anon-key"
# Server-only. Needed only for admin-provisioning scripts (creating the first
# admin via the Supabase Admin API) — never import this in client code.
SUPABASE_SERVICE_ROLE_KEY="ganti-dengan-service-role-key"

# ── Database (Prisma, points at the same Supabase Postgres instance) ──
# Project Settings > Database > Connection string in the Supabase dashboard.
# Pooled (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (port 5432) — used only by `prisma migrate`.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Integrasi Automated Recap (Flask) ──
# URL tool rekap Flask (dibuka dari halaman /admin/automated-recap).
RECAP_TOOL_URL="http://localhost:5000"
# Token bersama untuk webhook internal Flask -> dashboard (set status REKAP).
# Flask mengirim header: Authorization: Bearer <token ini>.
RECAP_SERVICE_TOKEN="ganti-dengan-token-acak-panjang"
