# ── Supabase ──
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ganti-dengan-anon-key"
# Server-only. Needed only for admin-provisioning scripts (creating the first
# admin via the Supabase Admin API) — never import this in client code.
SUPABASE_SERVICE_ROLE_KEY="ganti-dengan-service-role-key"

# ── Database (Prisma, points at the same Supabase Postgres instance) ──
# Project Settings > Database > Connection string in the Supabase dashboard.
# Pooled (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (port 5432) — used only by `prisma migrate`.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Integrasi Automated Recap (Flask) ──
# URL server Flask (internal — halaman /admin/automated-recap memproxy semua
# request ke sini, browser tidak pernah panggil Flask langsung).
# Port 5000 sering dipakai AirPlay Receiver di macOS — kalau bentrok, jalankan
# Flask dengan PORT=5001 dan samakan di sini.
RECAP_TOOL_URL="http://localhost:5000"
# Shared secret dipakai DUA ARAH — harus sama persis dengan RECAP_SERVICE_TOKEN
# di psikotes-automation/.env:
#   1. Flask -> Next.js: webhook set status REKAP (header dari Flask)
#   2. Next.js -> Flask: proxy /api/admin/recap/* (header dari server kita)
RECAP_SERVICE_TOKEN="ganti-dengan-token-acak-panjang"

# ── Google Sheets reading (Phase 13) — service account ──
# Service account JSON from GCP Console > IAM & Admin > Service Accounts >
# Keys > Add Key > JSON. A raw sheet is only readable once explicitly shared
# with this service account's email as Viewer — a GCP IAM role alone does
# not grant that. Reading only — see the OAuth section below for writes.
GOOGLE_SERVICE_ACCOUNT_EMAIL="nama-sa@project-id.iam.gserviceaccount.com"
# From the JSON's "private_key" field, pasted as-is (keep the literal \n
# sequences — google-sheets.ts unescapes them before use).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Google Drive writing (Phase 15) — OAuth, NOT the service account ──
# A bare service account has no Drive storage quota and cannot create files
# in a personal "My Drive" folder (only inside a paid-Workspace Shared
# Drive) — it can read shared content fine, just not write new files. So the
# recap-result upload authenticates as the results folder's actual owner via
# OAuth instead. OAuth Client ID from GCP Console > Credentials > Create
# Credentials > OAuth client ID > Desktop app.
GOOGLE_OAUTH_CLIENT_ID="ganti-dengan-oauth-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="ganti-dengan-oauth-client-secret"
# Obtained once via `node --env-file=.env scripts/google-oauth-setup.mjs` —
# opens a consent URL, you log in with the personal account that owns the
# results folder, and the script prints a refresh token to paste here.
# Long-lived; googleapis auto-refreshes the access token from it.
GOOGLE_OAUTH_REFRESH_TOKEN="ganti-dengan-refresh-token"

# One shared Drive folder for every school's recap result (not per-school —
# see CLAUDE.md / docs/ROADMAP.md Phase 15). Lives in the same personal
# account authorized above — no separate sharing step needed, since you're
# uploading as that account's own owner.
GOOGLE_DRIVE_RESULTS_FOLDER_ID="ganti-dengan-folder-id"
